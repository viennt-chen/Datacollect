# 数据库配置
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/dbname
AUTH_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/dbname

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT 配置（务必使用随机生成的密钥）
SECRET_KEY=your-random-secret-key-here

# MQTT 配置
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=
